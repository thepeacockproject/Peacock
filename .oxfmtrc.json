{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "semi": false,
    "tabWidth": 4,
    "trailingComma": "all",
    "printWidth": 80,
    "sortPackageJson": false,
    "ignorePatterns": [
        "node_modules",
        "userdata",
        "build",
        "contractSessions",
        "chunk*.js",
        "webui/dist",
        "*.plugin.js",
        "*Plugin.js",
        "components/contracts.json",
        "logs",
        "resources/**/*.json",
        "!resources/locale.json",
        "packaging/add_itemsize/*",
        "!packaging/add_itemsize/add_itemsize.js"
    ]
}
